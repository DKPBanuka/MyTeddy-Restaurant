generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  MANAGER
  CASHIER
  WAITER
  KITCHEN
}

enum ProductType {
  FOOD
  RETAIL
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
  VOID
}

enum PaymentMethod {
  CASH
  CARD
  ONLINE
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum PartyBookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum BookingType {
  PARTIAL
  EXCLUSIVE
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String?  @unique
  pin       String   @unique
  role      Role     @default(CASHIER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]
  partyBookings PartyBooking[]
}

model RolePermission {
  id          String   @id @default(uuid())
  role        Role     @unique
  permissions String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  products  Product[]
  addons    GlobalAddon[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          String        @id @default(uuid())
  name        String
  description String?
  price       Decimal       @db.Decimal(10, 2)
  type        ProductType
  barcode     String?       @unique
  imageUrl    String?
  isActive    Boolean       @default(true)
  categoryId  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  category     Category?    @relation(fields: [categoryId], references: [id])
  recipeBOMs   RecipeBOM[]
  retailStock  RetailStock?
  orderItems   OrderItem[]
  sizes        ProductSize[]
  packageItems PackageItem[]
}

model ProductSize {
  id        String   @id @default(uuid())
  name      String
  price     Decimal  @db.Decimal(10, 2)
  productId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  packageItems PackageItem[]
}

model GlobalAddon {
  id        String   @id @default(uuid())
  name       String   @unique
  price      Decimal  @db.Decimal(10, 2)
  categories Category[]
  createdAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Package {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  imageUrl    String?
  isActive    Boolean  @default(true)
  validFrom   DateTime?
  validUntil  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       PackageItem[]
  orderItems  OrderItem[]
}

model PackageItem {
  id        String   @id @default(uuid())
  packageId String
  productId String
  sizeId    String?
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  package   Package      @relation(fields: [packageId], references: [id], onDelete: Cascade)
  product   Product      @relation(fields: [productId], references: [id])
  size      ProductSize? @relation(fields: [sizeId], references: [id])
}


model Ingredient {
  id            String      @id @default(uuid())
  name          String
  stockQty      Decimal     @db.Decimal(12, 3)
  unitOfMeasure String      // e.g., GRAMS, ML, PIECE
  minLevel      Decimal     @db.Decimal(12, 3)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  recipeBOMs    RecipeBOM[]
}

model RecipeBOM {
  id           String     @id @default(uuid())
  productId    String
  ingredientId String
  quantity     Decimal    @db.Decimal(10, 3) 
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([productId, ingredientId])
}

model RetailStock {
  id              String   @id @default(uuid())
  productId       String   @unique
  stockQty        Int
  supplierDetails String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id              String        @id @default(uuid())
  orderNumber     String        @unique
  invoiceNumber   String        @unique
  tokenNumber     Int           @default(0)
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(UNPAID)
  orderType       OrderType     @default(DINE_IN)
  tableNumber     String?
  customerName    String?
  customerPhone   String?
  deliveryAddress String?
  tokenId         String?
  totalAmount     Decimal       @db.Decimal(10, 2) // Legacy or summary field
  subTotal        Decimal       @default(0) @db.Decimal(10, 2)
  discount        Decimal       @default(0) @db.Decimal(10, 2)
  grandTotal      Decimal       @default(0) @db.Decimal(10, 2)
  paymentMethod   PaymentMethod?
  amountReceived  Decimal?      @db.Decimal(10, 2)
  change          Decimal?      @db.Decimal(10, 2)
  refundReason    String?
  userId          String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user        User        @relation(fields: [userId], references: [id])
  orderItems  OrderItem[]
}

model OrderItem {
  id                 String   @id @default(uuid())
  orderId            String
  productId          String?
  packageId          String?
  quantity           Int
  unitPrice          Decimal  @db.Decimal(10, 2) // Current price at time of snapshot
  priceAtTimeOfSale  Decimal? @db.Decimal(10, 2) // Immutable historical price
  subtotal           Decimal  @db.Decimal(10, 2)
  notes              String?
  sizeId             String?
  addonIds           String[] // Array of GlobalAddon IDs

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id])
  package   Package? @relation(fields: [packageId], references: [id])
}

model PartyBooking {
  id              String             @id @default(uuid())
  customerId      String?            
  customerName    String
  customerPhone   String
  eventDate       DateTime
  startTime       DateTime           
  endTime         DateTime           
  guestCount      Int
  hallCharge      Decimal            @default(0) @db.Decimal(10, 2)
  menuTotal       Decimal            @default(0) @db.Decimal(10, 2)
  addonsTotal     Decimal            @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal            @default(0) @db.Decimal(10, 2)
  advancePaid     Decimal            @default(0) @db.Decimal(10, 2)
  status          PartyBookingStatus @default(PENDING)
  bookingType     BookingType        @default(PARTIAL)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  userId          String?
  user            User?              @relation(fields: [userId], references: [id])
}

model RestaurantSettings {
  id              String   @id @default(uuid())
  restaurantName  String
  address         String
  phone           String
  logoUrl         String?
  currencySymbol  String   @default("Rs.")
  taxRate         Float    @default(0)
  serviceCharge   Float    @default(0)
  packagingCharge Float    @default(0)
  receiptFooter   String?
  qrCodeUrl       String?
  wifiPassword    String?
  partyExclusiveCharge Float @default(5000)
  partyAdvancePercentage Float @default(30)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

