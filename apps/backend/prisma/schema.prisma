generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  MANAGER
  CASHIER
  WAITER
  KITCHEN
}

enum ProductType {
  FOOD
  RETAIL
}

enum PaymentStatus {
  UNPAID
  PAID
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum PartyBookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String?  @unique
  pin       String   @unique
  role      Role     @default(CASHIER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]
}

model Product {
  id          String        @id @default(uuid())
  name        String
  description String?
  price       Decimal       @db.Decimal(10, 2)
  type        ProductType
  barcode     String?       @unique
  imageUrl    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  recipeBOMs   RecipeBOM[]
  retailStock  RetailStock?
  orderItems   OrderItem[]
}

model Ingredient {
  id            String      @id @default(uuid())
  name          String
  stockQty      Decimal     @db.Decimal(12, 3)
  unitOfMeasure String      // e.g., GRAMS, ML, PIECE
  minLevel      Decimal     @db.Decimal(12, 3)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  recipeBOMs    RecipeBOM[]
}

model RecipeBOM {
  id           String     @id @default(uuid())
  productId    String
  ingredientId String
  quantity     Decimal    @db.Decimal(10, 3) 
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([productId, ingredientId])
}

model RetailStock {
  id              String   @id @default(uuid())
  productId       String   @unique
  stockQty        Int
  supplierDetails String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id          String      @id @default(uuid())
  orderNumber String      @unique
  status      OrderStatus @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID)
  orderType   OrderType   @default(DINE_IN)
  tableNumber String?
  customerName String?
  customerPhone String?
  deliveryAddress String?
  tokenId     String?
  totalAmount Decimal     @db.Decimal(10, 2)
  paymentMethod String?
  amountReceived Decimal? @db.Decimal(10, 2)
  change        Decimal?  @db.Decimal(10, 2)
  userId      String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id])
  orderItems  OrderItem[]
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Decimal  @db.Decimal(10, 2)
  subtotal  Decimal  @db.Decimal(10, 2)
  notes     String?

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])
}

model PartyBooking {
  id              String             @id @default(uuid())
  customerId      String             // Using simple string as per current convention, could link to User if needed
  customerName    String
  customerPhone   String
  eventDate       DateTime
  startTime       String             // Storing as HH:mm string for simpler time-slot logic
  endTime         String             // Storing as HH:mm string
  guestCount      Int
  hallCharge      Float              @default(0)
  menuTotal       Float              @default(0)
  addonsTotal     Float              @default(0)
  totalAmount     Float              @default(0)
  advancePaid     Float              @default(0)
  status          PartyBookingStatus @default(PENDING)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}
