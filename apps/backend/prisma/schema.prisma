generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String         @id @default(uuid())
  name          String
  email         String?        @unique
  pin           String         @unique
  password      String?        // For administrator access
  role          Role           @default(CASHIER)
  permissions   String[]       @default([])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  orders        Order[]
  partyBookings PartyBooking[]
  expenses      Expense[]
  auditLogs     AuditLog[]
}

model RolePermission {
  id          String   @id @default(uuid())
  role        Role     @unique
  permissions String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id        String        @id @default(uuid())
  name      String        @unique
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  products  Product[]
  addons    GlobalAddon[] @relation("CategoryToGlobalAddon")
}

model Product {
  id           String        @id @default(uuid())
  name         String
  description  String?
  price        Decimal       @db.Decimal(10, 2)
  type         ProductType
  barcode      String?       @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  categoryId   String?
  imageUrl     String?
  isActive     Boolean       @default(true)
  orderItems   OrderItem[]
  packageItems PackageItem[]
  category     Category?     @relation(fields: [categoryId], references: [id])
  sizes        ProductSize[]
  recipeBOMs   RecipeBOM[]
  retailStock  RetailStock?
}

model ProductSize {
  id           String        @id @default(uuid())
  name         String
  price        Decimal       @db.Decimal(10, 2)
  costPrice    Decimal       @default(0) @db.Decimal(10, 2)
  productId    String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  orderItems   OrderItem[]
  packageItems PackageItem[]
  product      Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model GlobalAddon {
  id         String     @id @default(uuid())
  name       String     @unique
  price      Decimal    @db.Decimal(10, 2)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  categories Category[] @relation("CategoryToGlobalAddon")
}

model Package {
  id          String        @id @default(uuid())
  name        String
  description String?
  price       Decimal       @db.Decimal(10, 2)
  imageUrl    String?
  isActive    Boolean       @default(true)
  validFrom   DateTime?
  validUntil  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  orderItems  OrderItem[]
  items       PackageItem[]
}

model PackageItem {
  id        String       @id @default(uuid())
  packageId String
  productId String
  sizeId    String?
  quantity  Int          @default(1)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  package   Package      @relation(fields: [packageId], references: [id], onDelete: Cascade)
  product   Product      @relation(fields: [productId], references: [id])
  size      ProductSize? @relation(fields: [sizeId], references: [id])
}

model Ingredient {
  id            String      @id @default(uuid())
  name          String
  stockQty      Decimal     @db.Decimal(12, 3)
  unitOfMeasure String
  minLevel      Decimal     @db.Decimal(12, 3)
  costPrice     Decimal     @default(0) @db.Decimal(10, 2)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  recipeBOMs    RecipeBOM[]
}

model RecipeBOM {
  id           String     @id @default(uuid())
  productId    String
  ingredientId String
  quantity     Decimal    @db.Decimal(10, 3)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, ingredientId])
}

model RetailStock {
  id              String   @id @default(uuid())
  productId       String   @unique
  stockQty        Int
  costPrice       Decimal  @default(0) @db.Decimal(10, 2)
  supplierDetails String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Expense {
  id          String   @id @default(uuid())
  description String
  amount      Decimal  @db.Decimal(10, 2)
  category    String   @default("GENERAL")
  date        DateTime @default(now())
  userId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User?    @relation(fields: [userId], references: [id])
}

model Customer {
  id            String         @id @default(uuid())
  name          String
  phone         String?        @unique
  email         String?        @unique
  address       String?
  points        Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  orders        Order[]
  partyBookings PartyBooking[]
}

model Order {
  id              String         @id @default(uuid())
  orderNumber     String         @unique
  status          OrderStatus    @default(PENDING)
  tableNumber     String?
  totalAmount     Decimal        @db.Decimal(10, 2)
  userId          String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  amountReceived  Decimal?       @db.Decimal(10, 2)
  change          Decimal?       @db.Decimal(10, 2)
  customerName    String?
  customerPhone   String?
  deliveryAddress String?
  discount        Decimal        @default(0) @db.Decimal(10, 2)
  grandTotal      Decimal        @default(0) @db.Decimal(10, 2)
  invoiceNumber   String         @unique
  orderType       OrderType      @default(DINE_IN)
  paymentMethod   PaymentMethod?
  paymentStatus   PaymentStatus  @default(UNPAID)
  refundReason    String?
  subTotal        Decimal        @default(0) @db.Decimal(10, 2)
  tokenId         String?
  tokenNumber     Int            @default(0)
  customerId      String?
  customer        Customer?      @relation(fields: [customerId], references: [id])
  user            User           @relation(fields: [userId], references: [id])
  orderItems      OrderItem[]
  payments        OrderPayment[]
}

model OrderPayment {
  id            String        @id @default(uuid())
  orderId       String
  paymentMethod PaymentMethod
  amount        Decimal       @db.Decimal(10, 2)
  paidItemIds   Json?         @default("[]")
  isSplit       Boolean       @default(false)
  splitDetails  Json?         // To store proportional tax, service charge, etc.
  createdAt     DateTime      @default(now())
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderItem {
  id                String       @id @default(uuid())
  orderId           String
  productId         String?
  quantity          Int
  unitPrice         Decimal      @db.Decimal(10, 2)
  subtotal          Decimal      @db.Decimal(10, 2)
  addonIds          String[]
  notes             String?
  packageId         String?
  priceAtTimeOfSale Decimal?     @db.Decimal(10, 2)
  sizeId            String?
  order             Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  package           Package?     @relation(fields: [packageId], references: [id])
  product           Product?     @relation(fields: [productId], references: [id])
  size              ProductSize? @relation(fields: [sizeId], references: [id])
}

model PartyBooking {
  id            String             @id @default(uuid())
  customerId    String?
  customerName  String
  customerPhone String
  eventDate     DateTime
  startTime     DateTime
  endTime       DateTime
  guestCount    Int
  hallCharge    Decimal            @default(0) @db.Decimal(10, 2)
  menuTotal     Decimal            @default(0) @db.Decimal(10, 2)
  addonsTotal   Decimal            @default(0) @db.Decimal(10, 2)
  serviceCharge Decimal            @default(0) @db.Decimal(10, 2)
  discount      Decimal            @default(0) @db.Decimal(10, 2)
  totalAmount   Decimal            @default(0) @db.Decimal(10, 2)
  advancePaid   Decimal            @default(0) @db.Decimal(10, 2)
  paymentMethod String             @default("CASH")
  status        PartyBookingStatus @default(PENDING)
  bookingType   BookingType        @default(PARTIAL)
  items         Json?              @default("[]")
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  userId        String?
  customer      Customer?          @relation(fields: [customerId], references: [id])
  user          User?              @relation(fields: [userId], references: [id])
}

model RestaurantSettings {
  id                     String   @id @default(uuid())
  restaurantName         String
  address                String
  phone                  String
  logoUrl                String?
  currencySymbol         String   @default("Rs.")
  taxRate                Float    @default(0)
  serviceCharge          Float    @default(0)
  packagingCharge        Float    @default(0)
  receiptFooter          String?
  qrCodeUrl              String?
  wifiPassword           String?
  partyExclusiveCharge   Float    @default(5000)
  partyAdvancePercentage Float    @default(30)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

enum Role {
  ADMIN
  MANAGER
  CASHIER
  WAITER
  KITCHEN
}

enum ProductType {
  FOOD
  RETAIL
}

enum PaymentStatus {
  UNPAID
  PAID
  PARTIAL
  REFUNDED
  VOID
}

enum PaymentMethod {
  CASH
  CARD
  QR
  ONLINE
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  COMPLETED
  PARTIALLY_PAID
  CANCELLED
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum PartyBookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum BookingType {
  PARTIAL
  EXCLUSIVE
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  details   Json     @default("{}")
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model TemporaryPin {
  id        String   @id @default(uuid())
  code      String   @unique
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  purpose   String   @default("VOID_ORDER")
  createdBy String
  createdAt DateTime @default(now())
}
